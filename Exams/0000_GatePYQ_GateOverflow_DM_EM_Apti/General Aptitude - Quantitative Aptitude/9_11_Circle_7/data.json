          "question": "<p><a name=\"204064\"></a><div itemprop=\"text\"><p>The area of a square is \\( d \\). What is the area of the circle which has the diagonal of the square as its diameter?</p>\n\n</div><br><br><b>GATE CSE 2018 | Question: GA-3</b></p>",
          "type": "single",
          "options": [
            "<p>\\( \\large{\\pi} d \\)</p>",
            "<p>\\( \\large{\\pi} d^2 \\)</p>",
            "<p>\\( \\dfrac{1}{4}\\large{\\pi} d^2 \\)</p>",
            "<p>\\( \\dfrac{1}{2}\\large{\\pi} d \\)</p>"
          ],
          "correct_answer": "<p>\\( \\dfrac{1}{2}\\large{\\pi} d \\)</p>",
          "marks": 1,
          "negative_marks": 0.33,
