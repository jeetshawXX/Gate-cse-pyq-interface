          "options": [
            "<p>\\( \\frac{\\left ( 2n \\right )!}{2^{n}} \\)</p>",
            "<p>\\( \\frac{\\left ( 2n \\right )!}{n!} \\)</p>",
            "<p>\\( \\frac{\\left ( 2n \\right )!}{2^n . n!} \\)</p>",
            "<p>\\( \\frac{n!}{2} \\)</p>",
            "<p>None of the above</p>"
